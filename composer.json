{
    "name": "tapao/custom-landing-page",
    "description": "Full-page HTML landing page for Flarum — no header or footer",
    "type": "flarum-extension",
    "require": {
        "flarum/core": "^1.8 || ^2.0"
    },
    "suggest": {
        "fof/direct-links": "Enables /login and /register direct-URL routes for landing page CTAs"
    },
    "extra": {
        "flarum-extension": {
            "title": "Full Landing Page",
            "icon": {
                "name": "fas fa-door-open",
                "backgroundColor": "#1a1a2e",
                "color": "#ffffff"
            }
        }
    },
    "autoload": {
        "psr-4": {
            "Tapao\\CustomLandingPage\\": "src/"
        }
    }
}
